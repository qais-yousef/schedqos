{
	"*/chrome": {
		"period": 16000000,
		"qos": "QOS_USER_INTERACTIVE"
	},
	"*/make": {
		"qos": "QOS_BACKGROUND"
	},
	"*/gcc": {
		"qos": "QOS_BACKGROUND"
	},
	"*/cc1": {
		"qos": "QOS_BACKGROUND"
	},
	"*/schbench": {
		"thread_qos": {
			"schbench-msg": "QOS_USER_INTERACTIVE",
			"schbench-worker": "QOS_USER_INITIATED"
		}
	},
	"*/hackbench": {
		"qos": "QOS_BACKGROUND"
	},
	"*/cyclictest": {
		"qos": "QOS_USER_INTERACTIVE"
	},
	"/usr/sbin/nginx": {
		"qos": "QOS_USER_INTERACTIVE"
	},
	"/opt/nginx-test/sbin/nginx": {
		"qos": "QOS_BACKGROUND"
	},
	"com.android.chrome*": {
		"period": 16000000,
		"qos": "QOS_USER_INTERACTIVE"
	}
}
